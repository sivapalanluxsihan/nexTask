{
  "entryFile": "src/index.ts",
  "noImplicitAdditionalProperties": "throw-on-extras",
  "controllerPathGlobs": ["src/controllers/**/*.ts"],
  "spec": {
    "outputDirectory": "src",
    "specVersion": 3,
    "name": "nexTask API Portal",
    "version": "1.0.0",
    "description": "Interactive developer reference for nexTask",
    "contact": {
      "name": "nexTask Development Team",
      "url": "https://nextask.sasivarnasarma.me"
    },
    "securityDefinitions": {
      "jwt": {
        "type": "apiKey",
        "name": "Authorization",
        "in": "header"
      }
    },
    "tags": [
      { "name": "System" },
      { "name": "Auth" },
      { "name": "Users" },
      { "name": "Projects" },
      { "name": "Project Members" },
      { "name": "Tasks" },
      { "name": "Task Assignments" },
      { "name": "Comments" },
      { "name": "Attachments" }
    ]
  },
  "routes": {
    "routesDir": "src",
    "authenticationModule": "src/middlewares/authentication"
  }
}
