# ──────────────────────────────────────────────────────────────
# nexTask Server — Environment Variables
# Copy this file to .env and fill in real values before running.
# ──────────────────────────────────────────────────────────────

# Database connection string for PostgreSQL
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE_NAME?schema=public
DATABASE_URL="postgresql://nextask_user:nextask_password@localhost:5432/nextask_db?schema=public"

# The port the backend server will listen on
PORT=3000

# JWT signing secret — MUST be at least 32 characters long
JWT_SECRET="change_me_to_a_random_string_at_least_32_chars"

# Set to "true" to allow anyone to register via POST /auth/register.
# Set to "false" (or remove) once the admin invitation workflow is active.
ALLOW_PUBLIC_REGISTRATION="true"

# ──────────────────────────────────────────────────────────────
# Seed script variables (only needed when running: pnpm seed)
# ──────────────────────────────────────────────────────────────
# SEED_ADMIN_EMAIL="admin@example.com"
# SEED_ADMIN_PASSWORD="ChangeMe!123"
# SEED_ADMIN_NAME="Admin User"
# SEED_TEST_EMAIL="test@example.com"
# SEED_TEST_PASSWORD="Temporary!1"
# SEED_TEST_NAME="Test User"
