# 🚀 nexTask API Integration Tests
# This file is compatible with the VS Code REST Client extension.
# It allows executing HTTP queries sequentially directly inside the editor.

@baseUrl = http://localhost:3000
@contentType = application/json

# User Credentials for Tests
@adminEmail = admin@example.com
@adminPassword = ChangeMe!123

@pmEmail = pm@example.com
@pmPassword = Password123!

@testEmail = test+{{$guid}}@example.com
@testPassword = Temporary!1
@testNewPassword = Password123!


# ==========================================
# 🔐 AUTHENTICATION & ONBOARDING
# ==========================================

### 1. Register a New User
# NOTE: Make sure ALLOW_PUBLIC_REGISTRATION="true" is set in server/.env
# @name registerRequest
POST {{baseUrl}}/auth/register
Content-Type: {{contentType}}

{
  "email": "{{testEmail}}",
  "password": "{{testPassword}}"
}

### 2. Login as Test Collaborator (First login, mustResetPassword will be true)
# @name testLoginRequest
POST {{baseUrl}}/auth/login
Content-Type: {{contentType}}

{
  "email": "{{testEmail}}",
  "password": "{{testPassword}}"
}

### 3. Extract Temporary JWT Token
@tempToken = {{testLoginRequest.response.body.data.token}}

### 4. Mandatory First-Login Password Reset
# @name resetPasswordRequest
POST {{baseUrl}}/auth/reset-password
Authorization: Bearer {{tempToken}}
Content-Type: {{contentType}}

{
  "currentPassword": "{{testPassword}}",
  "newPassword": "{{testNewPassword}}",
  "confirmNewPassword": "{{testNewPassword}}"
}

### 5. Extract Final Auth Token for Collaborator
@collAuthToken = {{resetPasswordRequest.response.body.data.token}}

### 6. Login as Project Manager
# @name pmLoginRequest
POST {{baseUrl}}/auth/login
Content-Type: {{contentType}}

{
  "email": "{{pmEmail}}",
  "password": "{{pmPassword}}"
}

### 7. Extract Auth Token for PM
@pmAuthToken = {{pmLoginRequest.response.body.data.token}}

### 8. Login as Admin
# @name adminLoginRequest
POST {{baseUrl}}/auth/login
Content-Type: {{contentType}}

{
  "email": "{{adminEmail}}",
  "password": "{{adminPassword}}"
}

### 9. Extract Auth Token for Admin
@adminAuthToken = {{adminLoginRequest.response.body.data.token}}


# ==========================================
# 👤 USER PROFILE & PROJECTS
# ==========================================

### 10. Get PM Profile
# @name pmProfileRequest
GET {{baseUrl}}/users/me
Authorization: Bearer {{pmAuthToken}}

### Extract PM User ID
@pmUserId = {{pmProfileRequest.response.body.data.id}}

### 11. Get Test Collaborator Profile
# @name collProfileRequest
GET {{baseUrl}}/users/me
Authorization: Bearer {{collAuthToken}}

### Extract Collaborator User ID
@collUserId = {{collProfileRequest.response.body.data.id}}

### 12. Update User Profile (Update PM's name)
PATCH {{baseUrl}}/users/me
Authorization: Bearer {{pmAuthToken}}
Content-Type: {{contentType}}

{
  "name": "Project Manager Senior",
  "email": "{{pmEmail}}"
}

### 13. Get Projects Authenticated User Belongs To (PM)
# @name getProjectsRequest
GET {{baseUrl}}/users/me/projects
Authorization: Bearer {{pmAuthToken}}

### Extract Project ID (Alpha Project)
@projectId = {{getProjectsRequest.response.body.data[0].id}}

### 14. Change Password Voluntarily (as Collaborator)
POST {{baseUrl}}/users/me/change-password
Authorization: Bearer {{collAuthToken}}
Content-Type: {{contentType}}

{
  "currentPassword": "{{testNewPassword}}",
  "newPassword": "{{testNewPassword}}",
  "confirmNewPassword": "{{testNewPassword}}"
}


# ==========================================
# 📂 PROJECTS CRUD
# ==========================================

### 14a. Create a New Project (as PM)
# @name createProjectRequest
POST {{baseUrl}}/projects
Authorization: Bearer {{pmAuthToken}}
Content-Type: {{contentType}}

{
  "name": "Beta Project",
  "description": "Secondary workspace for testing T2.4 crud functions."
}

### Extract New Project ID
@newProjectId = {{createProjectRequest.response.body.data.id}}

### 14b. View All Projects (as PM)
GET {{baseUrl}}/projects
Authorization: Bearer {{pmAuthToken}}

### 14c. View Single Project by ID (as PM)
GET {{baseUrl}}/projects/{{newProjectId}}
Authorization: Bearer {{pmAuthToken}}

### 14d. Update Project Details (as PM)
PUT {{baseUrl}}/projects/{{newProjectId}}
Authorization: Bearer {{pmAuthToken}}
Content-Type: {{contentType}}

{
  "name": "Beta Project Updated",
  "description": "Updated project description."
}

### 14e. Complete Project (as PM)
PATCH {{baseUrl}}/projects/{{newProjectId}}/complete
Authorization: Bearer {{pmAuthToken}}

### 14f. Archive Project (as PM)
PATCH {{baseUrl}}/projects/{{newProjectId}}/archive
Authorization: Bearer {{pmAuthToken}}

### 14g. Try to Delete Project (as PM - should fail with 403)
DELETE {{baseUrl}}/projects/{{newProjectId}}
Authorization: Bearer {{pmAuthToken}}

### 14h. Delete Project (as Admin - should succeed)
DELETE {{baseUrl}}/projects/{{newProjectId}}
Authorization: Bearer {{adminAuthToken}}


# ==========================================
# 📋 TASKS CRUD (With Required Project Scoping)
# ==========================================

### 15. Create a Task (Valid Input - Scoped to Project)
# @name createTaskRequest
POST {{baseUrl}}/tasks
Authorization: Bearer {{pmAuthToken}}
Content-Type: {{contentType}}

{
  "title": "Perform Task Controller Security Audit",
  "description": "Double check all validation bounds, user assignment integrity, and authentication status handlers.",
  "priority": "HIGH",
  "status": "TODO",
  "dueDate": "2027-12-31T23:59:59.000Z",
  "projectId": "{{projectId}}"
}

### Extract Task ID
@taskId = {{createTaskRequest.response.body.data.id}}

### 16. Get All Tasks (Requires projectId Query Parameter)
GET {{baseUrl}}/tasks?projectId={{projectId}}
Authorization: Bearer {{pmAuthToken}}

### 17. Get Task By ID
GET {{baseUrl}}/tasks/{{taskId}}
Authorization: Bearer {{pmAuthToken}}

### 18. Update Task Status & Details
PUT {{baseUrl}}/tasks/{{taskId}}
Authorization: Bearer {{pmAuthToken}}
Content-Type: {{contentType}}

{
  "status": "IN_PROGRESS",
  "description": "Audited security endpoints: Verified required projectId parameter checks in the controller."
}


# ==========================================
# 👥 PROJECT MEMBERSHIP & ROLES (T2.5)
# ==========================================

### 19. Get Project Members
GET {{baseUrl}}/projects/{{projectId}}/members
Authorization: Bearer {{pmAuthToken}}

### 20. Add Collaborator to Project
# @name addMemberRequest
POST {{baseUrl}}/projects/{{projectId}}/members
Authorization: Bearer {{pmAuthToken}}
Content-Type: {{contentType}}

{
  "userId": "{{collUserId}}",
  "role": "COLLABORATOR"
}

### 21. Get Member Details (Collaborator)
GET {{baseUrl}}/projects/{{projectId}}/members/{{collUserId}}
Authorization: Bearer {{pmAuthToken}}

### 22. Update Member Role (to PROJECT_MANAGER)
PATCH {{baseUrl}}/projects/{{projectId}}/members/{{collUserId}}
Authorization: Bearer {{pmAuthToken}}
Content-Type: {{contentType}}

{
  "role": "PROJECT_MANAGER"
}

### 23. Demote/Assign Member back as Collaborator
PATCH {{baseUrl}}/projects/{{projectId}}/members/{{collUserId}}/collaborator
Authorization: Bearer {{pmAuthToken}}

### 24. Promote Member as Project Manager (Admin Only endpoint)
PATCH {{baseUrl}}/projects/{{projectId}}/members/{{collUserId}}/project-manager
Authorization: Bearer {{adminAuthToken}}

### 25. Remove Member from Project
DELETE {{baseUrl}}/projects/{{projectId}}/members/{{collUserId}}
Authorization: Bearer {{pmAuthToken}}

### 26. Add Member Back (so they can perform collaborative tasks below)
POST {{baseUrl}}/projects/{{projectId}}/members
Authorization: Bearer {{pmAuthToken}}
Content-Type: {{contentType}}

{
  "userId": "{{collUserId}}",
  "role": "COLLABORATOR"
}


# ==========================================
# 💬 COLLABORATION (COMMENTS & ATTACHMENTS)
# ==========================================

### 27. Get Presigned Upload URL for attachment
# @name presignedUrlRequest
POST {{baseUrl}}/attachments/presigned-url
Authorization: Bearer {{pmAuthToken}}
Content-Type: {{contentType}}

{
  "filename": "design_mockup.png",
  "mimeType": "image/png",
  "fileSize": 204857
}

### 28. Extract Upload Key
@uploadKey = {{presignedUrlRequest.response.body.data.fileKey}}

### 29. Post a Comment to Task (with S3 upload fileKey)
# @name postCommentRequest
POST {{baseUrl}}/tasks/{{taskId}}/comments
Authorization: Bearer {{pmAuthToken}}
Content-Type: {{contentType}}

{
  "content": "Checking task comments logic and push dispatcher triggers.",
  "attachments": [
    {
      "filename": "design_mockup.png",
      "fileKey": "{{uploadKey}}",
      "mimeType": "image/png",
      "fileSize": 204857
    }
  ]
}

### Extract Comment ID
@commentId = {{postCommentRequest.response.body.data.id}}

### 30. Get All Comments for Task
GET {{baseUrl}}/tasks/{{taskId}}/comments
Authorization: Bearer {{pmAuthToken}}

### 31. Get Presigned Upload URL for standalone attachment
# @name standalonePresignedRequest
POST {{baseUrl}}/attachments/presigned-url
Authorization: Bearer {{pmAuthToken}}
Content-Type: {{contentType}}

{
  "filename": "sprint_report.pdf",
  "mimeType": "application/pdf",
  "fileSize": 1048576
}

### Extract Standalone Upload Key
@standaloneKey = {{standalonePresignedRequest.response.body.data.fileKey}}

### 32. Upload/Register Independent Attachment Metadata
# @name createAttachmentRequest
POST {{baseUrl}}/tasks/{{taskId}}/attachments
Authorization: Bearer {{pmAuthToken}}
Content-Type: {{contentType}}

{
  "filename": "sprint_report.pdf",
  "fileKey": "{{standaloneKey}}",
  "mimeType": "application/pdf",
  "fileSize": 1048576
}

### Extract Attachment ID
@attachmentId = {{createAttachmentRequest.response.body.data.id}}

### 33. Get All Attachments for Task
GET {{baseUrl}}/tasks/{{taskId}}/attachments
Authorization: Bearer {{pmAuthToken}}

### 34. Delete Attachment Metadata (and S3 object)
DELETE {{baseUrl}}/attachments/{{attachmentId}}
Authorization: Bearer {{pmAuthToken}}

### 35. Delete Comment
DELETE {{baseUrl}}/comments/{{commentId}}
Authorization: Bearer {{pmAuthToken}}


# ==========================================
# 🔔 WEB PUSH NOTIFICATIONS
# ==========================================

### 36. Get VAPID Public Key for Web Push
GET {{baseUrl}}/push/key
Authorization: Bearer {{pmAuthToken}}

### 37. Register/Subscribe to Push Notifications
POST {{baseUrl}}/push/subscribe
Authorization: Bearer {{pmAuthToken}}
Content-Type: {{contentType}}

{
  "endpoint": "https://fcm.googleapis.com/fcm/send/mock-device-endpoint-12345",
  "keys": {
    "p256dh": "BFCxp-QcTjI...",
    "auth": "5A8B..."
  }
}

### 38. Unsubscribe from Push Notifications
POST {{baseUrl}}/push/unsubscribe
Authorization: Bearer {{pmAuthToken}}
Content-Type: {{contentType}}

{
  "endpoint": "https://fcm.googleapis.com/fcm/send/mock-device-endpoint-12345"
}


# ==========================================
# 🧹 CLEANUP & TEARDOWN
# ==========================================

### 39. Delete Task
DELETE {{baseUrl}}/tasks/{{taskId}}
Authorization: Bearer {{pmAuthToken}}


# ==========================================
# ⚠️ NEGATIVE & VALIDATION TESTS
# ==========================================

### 40. Create a Task without projectId
# Should return 422 Unprocessable Entity due to validation failure
POST {{baseUrl}}/tasks
Authorization: Bearer {{pmAuthToken}}
Content-Type: {{contentType}}

{
  "title": "Orphaned Task",
  "description": "Should fail because projectId is required."
}

### 41. Get Tasks without projectId
# Should return 422 Unprocessable Entity
GET {{baseUrl}}/tasks
Authorization: Bearer {{pmAuthToken}}

### 42. Weak Password Test
# Should return 400 Bad Request
POST {{baseUrl}}/auth/reset-password
Authorization: Bearer {{tempToken}}
Content-Type: {{contentType}}

{
  "currentPassword": "{{testPassword}}",
  "newPassword": "weak",
  "confirmNewPassword": "weak"
}

### 43. Create a Project as Collaborator (Should fail with 403)
POST {{baseUrl}}/projects
Authorization: Bearer {{collAuthToken}}
Content-Type: {{contentType}}

{
  "name": "Collaborator Hack Project",
  "description": "Should fail because collaborators are not authorized to create projects."
}

### 44. Create a Project with too short name (Should fail with 400)
POST {{baseUrl}}/projects
Authorization: Bearer {{pmAuthToken}}
Content-Type: {{contentType}}

{
  "name": "Ab",
  "description": "Should fail because name requires minimum 3 characters."
}

### 45. Create a Private Project (Admin) and Access it as Collaborator (Should fail with 403)
# @name adminCreateProject
POST {{baseUrl}}/projects
Authorization: Bearer {{adminAuthToken}}
Content-Type: {{contentType}}

{
  "name": "Top Secret Project",
  "description": "Accessible only to Admin."
}

### Extract Secret Project ID
@secretProjectId = {{adminCreateProject.response.body.data.id}}

### 46. Attempt to Fetch Secret Project (as Collaborator - should return 403)
GET {{baseUrl}}/projects/{{secretProjectId}}
Authorization: Bearer {{collAuthToken}}

### 47. Clean up Secret Project (as Admin)
DELETE {{baseUrl}}/projects/{{secretProjectId}}
Authorization: Bearer {{adminAuthToken}}