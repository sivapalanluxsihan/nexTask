{
  "name": "nextask-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "nexTask - Collaborative Task Management System Monorepo",
  "scripts": {
    "dev": "pnpm --parallel run dev",
    "build": "pnpm --recursive run build",
    "prod": "pnpm run build && pnpm --parallel run start",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css}\"",
    "lint": "pnpm --recursive run lint"
  },
  "devDependencies": {
    "prettier": "^3.2.5",
    "@trivago/prettier-plugin-sort-imports": "^4.3.0",
    "typescript": "^6.0.2"
  }
}
