# ──────────────────────────────────────────────────────────────────────────────
# nexTask Monorepo — Consolidated Environment Variables Template
# Copy this file to .env at the repository root and configure the values.
# ──────────────────────────────────────────────────────────────────────────────

# 📡 SERVER CONFIGURATION
# ──────────────────────────────────────────────────────────────────────────────
# The port the backend server will listen on.
PORT=3000

# Database connection string for PostgreSQL.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE_NAME?schema=public
DATABASE_URL="postgresql://username:password@hostname:port/database?schema=public"

# JWT signing secret (MUST be at least 32 characters long).
JWT_SECRET="generate_a_secure_long_random_string_here"

# Set to "true" to allow anyone to register via POST /auth/register.
# Set to "false" once the admin invitation workflow is active.
ALLOW_PUBLIC_REGISTRATION="true"

# 📦 S3 / COMPATIBLE OBJECT STORAGE (AWS S3, Cloudflare R2, MinIO, etc.)
# ──────────────────────────────────────────────────────────────────────────────
# Bucket or container name
S3_BUCKET_NAME="my-bucket"

# Access credentials
AWS_ACCESS_KEY_ID="your-access-key-id"
AWS_SECRET_ACCESS_KEY="your-secret-access-key"

# Region:
# - Required for Amazon S3 (e.g., us-east-1)
# - Use "auto" for Cloudflare R2
# - Optional/ignored for MinIO
AWS_REGION="us-east-1"

# Custom endpoint:
# - Leave empty/commented out for Amazon S3
# - Required for Cloudflare R2 (e.g., https://<account-id>.r2.cloudflarestorage.com)
# - Required for MinIO (e.g., http://localhost:9000)
S3_ENDPOINT=""

# Force path-style URLs:
# - false for Amazon S3
# - false for Cloudflare R2
# - true for MinIO
S3_FORCE_PATH_STYLE="false"

# 🔔 WEB PUSH (VAPID) NOTIFICATIONS
# ──────────────────────────────────────────────────────────────────────────────
# Run: pnpm --filter @nextask/server exec ts-node src/scripts/generate-vapid.ts
# to generate a valid public/private VAPID key pair.
VAPID_PUBLIC_KEY="Base64 encoded VAPID public key"
VAPID_PRIVATE_KEY="Base64 encoded VAPID private key"
VAPID_SUBJECT="mailto:admin@example.com"

# ✉ SMTP / EMAIL CONFIGURATION
# ──────────────────────────────────────────────────────────────────────────────
# The hostname or IP address of the SMTP server (e.g., smtp.gmail.com).
SMTP_HOST="smtp.gmail.com"

# The port of the SMTP server (usually 587 for TLS, or 465 for SSL/SMTPS).
SMTP_PORT=587

# Username credentials for SMTP authentication.
SMTP_USER="your_email@gmail.com"

# Password credentials for SMTP authentication.
SMTP_PASS="your_app_password_here"

# Set to "true" if the port is 465 (SSL/SMTPS), or "false" otherwise.
SMTP_SECURE="false"

# The email address that the emails will be sent from.
MAIL_FROM='"nexTask" <your_email@gmail.com>'

# The frontend client base URL used in the email reset links.
CLIENT_URL="http://localhost:5173"

# 🌱 SEED DATA CONFIGURATION (Only used when running: pnpm seed)
# ──────────────────────────────────────────────────────────────────────────────
SEED_ADMIN_EMAIL="admin@example.com"
SEED_ADMIN_PASSWORD="ChangeMe!123"
SEED_ADMIN_NAME="Admin User"
SEED_PM_EMAIL="pm@nextask.com"
SEED_PM_PASSWORD="Password123!"
SEED_PM_NAME="Project Manager"
SEED_TEST_EMAIL="test@example.com"
SEED_TEST_PASSWORD="Temporary!1"
SEED_TEST_NAME="Test User"

# 💻 CLIENT CONFIGURATION
# ──────────────────────────────────────────────────────────────────────────────
# The URL where the backend API is hosted. Vite loads this during build/run.
VITE_API_URL="http://localhost:3000"
